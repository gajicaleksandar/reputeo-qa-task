{
  "name": "reputeo-qa-task",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "test": "cypress run",
    "report:clean": "rimraf cypress/reports cypress/screenshots",
    "cy:run:report": "cypress run || true",
    "report:merge": "mochawesome-merge cypress/reports/*.json > cypress/reports/combined-report.json",
    "report:generate": "marge cypress/reports/combined-report.json --reportDir cypress/reports --reportFilename index --inline",
    "test:report": "npm run report:clean && npm run cy:run:report && npm run report:merge && npm run report:generate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "cypress": "^15.17.0",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2",
    "rimraf": "^6.1.3"
  }
}
